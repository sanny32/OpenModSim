if(NOT EXISTS "@CMAKE_CURRENT_BINARY_DIR@/install_manifest.txt")
    message(FATAL_ERROR "Cannot find install manifest: @CMAKE_CURRENT_BINARY_DIR@/install_manifest.txt")
endif()

file(READ "@CMAKE_CURRENT_BINARY_DIR@/install_manifest.txt" installed_files)
string(REPLACE "\n" ";" installed_files "${installed_files}")

foreach(installed_file ${installed_files})
    if(installed_file STREQUAL "")
        continue()
    endif()

    if(EXISTS "${installed_file}" OR IS_SYMLINK "${installed_file}")
        message(STATUS "Removing ${installed_file}")
        file(REMOVE "${installed_file}")
    else()
        message(STATUS "Skipping missing file: ${installed_file}")
    endif()
endforeach()

if("@CMAKE_SYSTEM_NAME@" STREQUAL "Windows")
    if(EXISTS "@CMAKE_INSTALL_PREFIX@")
        message(STATUS "Removing install directory @CMAKE_INSTALL_PREFIX@")
        file(REMOVE_RECURSE "@CMAKE_INSTALL_PREFIX@")
    else()
        message(STATUS "Skipping missing install directory: @CMAKE_INSTALL_PREFIX@")
    endif()
endif()

if("@CMAKE_SYSTEM_NAME@" STREQUAL "Linux")
    execute_process(COMMAND update-mime-database "@CMAKE_INSTALL_PREFIX@/share/mime")
    execute_process(COMMAND xdg-desktop-menu forceupdate)
    execute_process(COMMAND update-desktop-database -q "@CMAKE_INSTALL_PREFIX@/share/applications")
    execute_process(COMMAND gtk-update-icon-cache -q -t -f "@CMAKE_INSTALL_PREFIX@/share/icons/hicolor")
endif()
